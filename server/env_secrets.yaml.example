# Production secrets for App Engine, included from app.yaml.
# Copy to `env_secrets.yaml` (gitignored) and fill in real values before deploying.
env_variables:
  SCHEDULER_CALLER_SA: "scheduler-caller-for-appengine@<project>.iam.gserviceaccount.com"
  GEMINI_API_KEY: "your-gemini-api-key"
  BROWSERLESSIO_TOKEN: "your-browserless-token"
