# Local development secrets. Copy to `.env` (gitignored) and fill in real values.
# Read by AppConfig.kt via dotenv-kotlin when running the server locally.
SCHEDULER_CALLER_SA=scheduler-caller-for-appengine@<project>.iam.gserviceaccount.com
GEMINI_API_KEY=your-gemini-api-key
BROWSERLESSIO_TOKEN=your-browserless-token
